# .env.example — copy to .env and fill in your values.
# This file is safe to commit. .env is not (it holds real secrets).
#
# Active services that read this file: chat-agent, mcp-server.
# Legacy services (policy-engine, gateway, agent-executor) are not used.

# ── LLM backend ──────────────────────────────────────────────────────────────
# "ollama" = fully local, no cloud calls.
# "openai_compatible" = any OpenAI-compatible API (DeepSeek, GitHub Models, etc.)
LLM_PROVIDER=ollama
OLLAMA_CHAT_MODEL=llama3

# Only needed when LLM_PROVIDER=openai_compatible:
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=your_key_here
# OPENAI_MODEL=deepseek-chat
# OPENAI_PROVIDER_LABEL=DeepSeek

# ── Ollama (local chat only — see below for embeddings) ──────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Embeddings ────────────────────────────────────────────────────────────────
# Served by the bundled "embeddings" service in docker-compose.yml (Hugging
# Face Text Embeddings Inference), not Ollama. Default already matches that
# service's published port for native dev; override only if you're running it
# elsewhere. The model it serves is fixed by the service's own MODEL_ID and is
# not meant to be changed after documents exist — see embeddings.py.
# EMBEDDINGS_BASE_URL=http://localhost:8082

# ── Vector database ───────────────────────────────────────────────────────────
# When running chat-agent locally (uvicorn): http://localhost:6333
# When running inside Docker Compose: http://qdrant:6333  (set in docker-compose.yml)
QDRANT_URL=http://localhost:6333

# ── PM integrations (read by mcp-server, not by chat-agent) ──────────────────
# Leave blank if you don't use Jira/GitHub sync.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token

GITHUB_TOKEN=your_github_pat

# ── Optional ──────────────────────────────────────────────────────────────────
# Web search backend for mcp-server's web_search tool (services/mcp-server/
# internal/tools/web.go), in priority order: SearXNG > Brave > DuckDuckGo
# (last-resort scrape fallback, no config needed).
# SEARXNG_BASE_URL=http://localhost:8085   # bundled via docker-compose.yml's "searxng" service
# BRAVE_SEARCH_API_KEY=your_brave_key      # alternative to SearXNG; requires a (free-tier) signup
# MCP_BASE_URL=http://localhost:8083       # default; override if mcp-server runs elsewhere
