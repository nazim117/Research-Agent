# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file — tracked so CI can use it without reconstruction
# go.work
# go.work.sum

# env file
.env

*venv/
*.venv/
*.db
*.log

# Audit logs produced by the gateway at runtime
*.jsonl

# Windows NUL device artifact
nul

# Secrets
# Ignore configuration files that contain secrets
config/secrets.yml
# Ignore any files that may contain API keys
*.key
# Ignore JSON files that may contain sensitive data
*.json
# Allow the detect-secrets baseline (it's a JSON file, not a secret)
!.secrets.baseline
# Allow the shared "Run All" dev task (no secrets, just task definitions)
!.vscode/tasks.json
# Other common sensitive files
*.pem
*.crt
# Ignore other common patterns
secrets/

# Editor/IDE
.idea/
# .vscode/
.gitnexus

docs/

**/__pycache__/